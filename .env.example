# Connection string de CockroachDB Cloud (Serverless).
# Obtenerla desde: https://cockroachlabs.cloud -> tu cluster -> "Connect"
# Formato típico:
# postgresql://<usuario>:<password>@<host>:26257/<database>?sslmode=verify-full
DATABASE_URL="postgresql://usuario:password@host:26257/estacion_mascotera?sslmode=verify-full"

# NextAuth
AUTH_SECRET="generar-con: openssl rand -base64 32"
