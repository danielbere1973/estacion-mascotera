generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Usuarios (socios)
// ---------------------------------------------------------------------------

enum RolUsuario {
  ADMIN
  LECTOR_RESTRINGIDO
}

model Usuario {
  id           Int        @id @default(sequence())
  nombre       String
  apellido     String
  email        String     @unique
  passwordHash String
  activo       Boolean    @default(true)
  rol          RolUsuario @default(ADMIN)
  createdAt    DateTime   @default(now())

  // Si el rol es LECTOR_RESTRINGIDO, limita lo que puede ver a un proveedor puntual.
  proveedorRestrictoId Int?
  proveedorRestricto   Proveedor? @relation("UsuarioProveedorRestricto", fields: [proveedorRestrictoId], references: [id])

  compras       Compra[]
  ventas        Venta[]
  gastos        Gasto[]
  gastosPagados Gasto[] @relation("GastoPagadoPor")
  logsActividad LogActividad[]
}

// ---------------------------------------------------------------------------
// Catálogo de productos
// ---------------------------------------------------------------------------

enum CategoriaProducto {
  ALIMENTO
  POUCH
  LATA
  SNACK
  GOLOSINA
}

enum Presentacion {
  BOLSA_CERRADA
  CAJA_CERRADA
  INDIVIDUAL
}

enum UnidadMedida {
  KILOGRAMOS
  GRAMOS
  LITROS
  MILILITROS
  UNIDAD
}

model Producto {
  id        Int               @id @default(sequence())
  sku       String            @unique
  nombre    String
  marca     String
  categoria CategoriaProducto
  presentacion Presentacion

  // Cómo se mide el producto (ej: 15 Kg, 500 ml, 12 Unidad para una caja x12)
  unidadMedida UnidadMedida @default(UNIDAD)
  contenido    Decimal      @default(1)

  stockActual Int @default(0)

  // Precios
  precioCostoUnitario Decimal @default(0)
  // Recargo aplicado sobre el costo para sugerir el precio de venta (ej: 30 = +30%)
  margenPorcentaje    Decimal @default(30)
  precioVenta         Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  compras        Compra[]
  detalleVentas  DetalleVenta[]
  historialStock HistorialStockMayorista[]

  @@index([categoria])
}

// ---------------------------------------------------------------------------
// Proveedores
// ---------------------------------------------------------------------------

model Proveedor {
  id        Int     @id @default(sequence())
  nombre    String
  direccion String?
  contacto  String?

  compras           Compra[]
  historialMayorista HistorialStockMayorista[]
  usuariosRestringidos Usuario[] @relation("UsuarioProveedorRestricto")
}

// ---------------------------------------------------------------------------
// Compras (ingresos de mercadería)
// ---------------------------------------------------------------------------

model Compra {
  id          Int @id @default(sequence())
  proveedorId Int
  productoId  Int

  cantidad            Int
  precioCostoUnitario Decimal
  // Descuento aplicado por el proveedor sobre el precio de costo (ej: pago contado)
  descuentoPorcentaje Decimal  @default(0)
  costoEnvio          Decimal? @default(0)
  numeroPedido        String?
  facturado           Boolean  @default(false)
  numeroFactura       String?
  fechaCompra         DateTime @default(now())

  usuarioId Int

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  producto  Producto  @relation(fields: [productoId], references: [id])
  usuario   Usuario   @relation(fields: [usuarioId], references: [id])

  @@index([fechaCompra])
  @@index([productoId])
}

// ---------------------------------------------------------------------------
// Clientes
// ---------------------------------------------------------------------------

model Cliente {
  id        Int     @id @default(sequence())
  nombre    String
  apellido  String
  direccion String
  telefono  String
  email     String?

  ventas Venta[]
}

// ---------------------------------------------------------------------------
// Ventas
// ---------------------------------------------------------------------------

enum CanalVenta {
  TIENDANUBE
  WHATSAPP
  TELEFONO
}

model Venta {
  id        Int @id @default(sequence())
  clienteId Int

  canalVenta    CanalVenta
  medioPago     String
  costoEnvio    Decimal    @default(0)
  facturado     Boolean    @default(false)
  numeroFactura String?
  fechaVenta    DateTime   @default(now())

  usuarioId Int

  cliente  Cliente        @relation(fields: [clienteId], references: [id])
  usuario  Usuario        @relation(fields: [usuarioId], references: [id])
  detalles DetalleVenta[]

  @@index([fechaVenta])
  @@index([clienteId])
}

model DetalleVenta {
  id      Int @id @default(sequence())
  ventaId Int
  productoId Int

  cantidad            Int
  precioVentaUnitario Decimal
  // Descuento aplicado a este producto en la venta
  descuentoPorcentaje Decimal  @default(0)

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@index([ventaId])
  @@index([productoId])
}

// ---------------------------------------------------------------------------
// Gastos
// ---------------------------------------------------------------------------

enum CategoriaGasto {
  MONOTRIBUTO
  TELEFONO
  COMMUNITY_MANAGER
  PUBLICIDAD
  SOPORTE_IT
  OTROS
}

model Gasto {
  id             Int            @id @default(sequence())
  categoriaGasto CategoriaGasto
  monto          Decimal
  descripcion    String?
  fechaGasto     DateTime       @default(now())

  usuarioId Int?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  // Quién pagó el gasto (puede ser distinto de quién lo cargó en el sistema).
  pagadoPorId Int?
  pagadoPor   Usuario? @relation("GastoPagadoPor", fields: [pagadoPorId], references: [id])

  @@index([fechaGasto])
}

// ---------------------------------------------------------------------------
// Log de actividad (auditoría: quién hizo qué y cuándo)
// ---------------------------------------------------------------------------

enum AccionLog {
  CREAR
  ACTUALIZAR
  ELIMINAR
}

enum EntidadLog {
  COMPRA
  VENTA
  GASTO
  PRODUCTO
  USUARIO
  PROVEEDOR
}

model LogActividad {
  id        Int        @id @default(sequence())
  usuarioId Int
  accion    AccionLog
  entidad   EntidadLog
  entidadId Int?
  detalle   String?
  fecha     DateTime   @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([fecha])
  @@index([entidad, entidadId])
}

// ---------------------------------------------------------------------------
// Historial de stock mayorista (importaciones de los viernes)
// ---------------------------------------------------------------------------

model HistorialStockMayorista {
  id         Int @id @default(sequence())
  productoId Int?
  proveedorId Int?

  // Código del producto en la lista de precios del mayorista (no es el SKU propio)
  sku    String
  nombre String?

  precioCostoScraped   Decimal
  precioConDescuento   Decimal?
  tamanios             String?
  // Stock que tiene el MAYORISTA disponible (informativo, no es nuestro stock)
  estadoStockMayorista String?

  fechaImportacion DateTime @default(now())

  producto  Producto?  @relation(fields: [productoId], references: [id])
  proveedor Proveedor? @relation(fields: [proveedorId], references: [id])

  @@index([fechaImportacion])
  @@index([sku])
  @@index([proveedorId])
}
